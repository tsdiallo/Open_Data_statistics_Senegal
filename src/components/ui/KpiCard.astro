---
import { formatNumber } from "@/lib/format";
import SourceBadge from "./SourceBadge.astro";
import type { DataNature, Source } from "@/lib/types";

interface Props {
  label: string;
  value: number | string;
  unit?: string;
  hint?: string;
  source: Source;
  nature: DataNature;
  compact?: boolean;
}
const { label, value, unit, hint, source, nature, compact = true } = Astro.props;
const display = typeof value === "number" ? formatNumber(value, { compact }) : value;
---
<article class="card flex flex-col gap-3">
  <p class="text-sm font-medium text-ink-700">{label}</p>
  <p class="text-3xl sm:text-4xl font-semibold text-baobab-800 tabular-nums">
    {display}{unit ? <span class="text-base text-ink-500 font-normal ml-1">{unit}</span> : null}
  </p>
  {hint ? <p class="text-sm text-ink-500">{hint}</p> : null}
  <SourceBadge source={source} nature={nature} />
</article>
