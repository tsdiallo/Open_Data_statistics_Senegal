---
import SourceBadge from "./SourceBadge.astro";
import type { DataNature, Source } from "@/lib/types";

interface Props {
  title: string;
  subtitle?: string;
  source: Source;
  nature: DataNature;
  explanation?: string;
}
const { title, subtitle, source, nature, explanation } = Astro.props;
---
<article class="card flex flex-col gap-4">
  <header class="flex flex-col gap-1">
    <h3 class="display text-xl sm:text-2xl text-ink-900 leading-tight">{title}</h3>
    {subtitle ? <p class="text-sm text-ink-500">{subtitle}</p> : null}
  </header>
  <div class="min-h-[260px]">
    <slot />
  </div>
  {explanation ? (
    <p class="text-sm text-ink-700 leading-relaxed border-l border-sun-500 pl-3.5 italic">
      {explanation}
    </p>
  ) : null}
  <div class="mt-auto pt-2 border-t border-line/60">
    <SourceBadge source={source} nature={nature} />
  </div>
</article>
