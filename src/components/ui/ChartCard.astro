---
import SourceBadge from "./SourceBadge.astro";
import type { DataNature, Source } from "@/lib/types";

interface Props {
  title: string;
  subtitle?: string;
  source: Source;
  nature: DataNature;
  explanation?: string;
}
const { title, subtitle, source, nature, explanation } = Astro.props;
---
<article class="card flex flex-col gap-4">
  <header class="flex flex-col gap-1">
    <h3 class="text-lg font-semibold text-baobab-800">{title}</h3>
    {subtitle ? <p class="text-sm text-ink-500">{subtitle}</p> : null}
  </header>
  <div class="min-h-[260px]">
    <slot />
  </div>
  {explanation ? (
    <p class="text-sm text-ink-700 leading-relaxed border-l-2 border-sun-500 pl-3">
      {explanation}
    </p>
  ) : null}
  <SourceBadge source={source} nature={nature} />
</article>
