---
const links = [
  { href: "/", label: "Accueil" },
  { href: "/demographie", label: "Démographie" },
  { href: "/economie", label: "Économie" },
  { href: "/climat", label: "Climat" },
  { href: "/methodologie", label: "Méthodologie" },
];
const path = Astro.url.pathname;
---
<header class="border-b border-ink-900/5 bg-white/80 backdrop-blur sticky top-0 z-30">
  <div class="container-page flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2 font-semibold text-baobab-800">
      <span aria-hidden="true" class="inline-block h-3 w-3 rounded-full bg-sun-500"></span>
      Sénégal en chiffres
    </a>
    <nav aria-label="Navigation principale">
      <ul class="flex flex-wrap items-center gap-4 sm:gap-6 text-sm">
        {links.map((l) => (
          <li>
            <a
              href={l.href}
              class:list={[
                "hover:text-baobab-700 transition",
                path === l.href ? "text-baobab-800 font-semibold" : "text-ink-700",
              ]}
              aria-current={path === l.href ? "page" : undefined}
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
