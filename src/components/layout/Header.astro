---
const links = [
  { href: "/", label: "Accueil" },
  { href: "/demographie", label: "Démographie" },
  { href: "/economie", label: "Économie" },
  { href: "/climat", label: "Climat" },
  { href: "/methodologie", label: "Méthodologie" },
];
const path = Astro.url.pathname;
---
<header class="border-b border-line bg-paper/85 backdrop-blur sticky top-0 z-30">
  <div class="container-page flex items-center justify-between h-16">
    <a href="/" class="flex items-center gap-2.5 group">
      <span aria-hidden="true" class="relative inline-flex h-5 w-5 items-center justify-center rounded-full bg-flag-green">
        <span class="absolute inset-1 rounded-full bg-flag-yellow"></span>
        <span class="relative h-1.5 w-1.5 rounded-full bg-flag-red"></span>
      </span>
      <span class="display text-lg text-ink-900 leading-none group-hover:text-baobab-700 transition">
        Sénégal <em class="not-italic text-baobab-700">en chiffres</em>
      </span>
    </a>
    <nav aria-label="Navigation principale">
      <ul class="flex flex-wrap items-center gap-5 sm:gap-7 text-sm">
        {links.slice(1).map((l) => (
          <li>
            <a
              href={l.href}
              class:list={[
                "hover:text-ink-900 transition",
                path === l.href ? "text-ink-900 font-medium" : "text-ink-500",
              ]}
              aria-current={path === l.href ? "page" : undefined}
            >
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>
  </div>
</header>
