---
import "@/styles/global.css";
import Header from "./Header.astro";
import Footer from "./Footer.astro";

interface Props {
  title: string;
  description?: string;
}
const { title, description = "Visualisation simple et pédagogique des données publiques du Sénégal." } = Astro.props;
const fullTitle = title === "Sénégal en chiffres" ? title : `${title} — Sénégal en chiffres`;
---
<!doctype html>
<html lang="fr">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="color-scheme" content="light" />
    <meta name="theme-color" content="#FAFAF5" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Instrument+Serif:ital@0;1&display=swap"
    />
    <title>{fullTitle}</title>
  </head>
  <body class="min-h-screen flex flex-col">
    <div class="flag-strip" aria-hidden="true"></div>
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 bg-white px-3 py-2 rounded shadow">
      Aller au contenu
    </a>
    <Header />
    <main id="main" class="container-page py-10 sm:py-16 flex-1">
      <slot />
    </main>
    <Footer />
  </body>
</html>
