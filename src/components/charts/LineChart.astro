---
import type { DataPoint } from "@/lib/types";

interface Props {
  id: string;
  series: DataPoint[];
  label: string;
  unit?: string;
  color?: string;
  rangeFilter?: boolean;
}
const { id, series, label, unit = "", color = "#155f3b", rangeFilter = false } = Astro.props;
const safeId = `chart-${id}`;
const payload = JSON.stringify({ series, label, unit, color });
---
{series.length === 0 ? (
  <div class="flex items-center justify-center h-[260px] rounded-lg bg-sand-100 text-sm text-ink-500 px-4 text-center">
    Données indisponibles pour le moment. Elles seront renseignées au prochain rafraîchissement.
  </div>
) : (
  <div>
    {rangeFilter && (
      <div class="flex items-center gap-1 mb-3" role="group" aria-label="Période affichée">
        {(["5", "10", "all"] as const).map((r) => (
          <button
            type="button"
            data-range={r}
            data-target={safeId}
            class="range-btn text-xs px-2.5 py-1 rounded-full ring-1 ring-ink-900/10 hover:bg-sand-100 data-[active=true]:bg-baobab-700 data-[active=true]:text-white data-[active=true]:ring-baobab-700"
            data-active={r === "all"}
          >
            {r === "all" ? "Tout" : `${r} ans`}
          </button>
        ))}
      </div>
    )}
    <canvas id={safeId} role="img" aria-label={label} class="w-full max-h-[320px]"></canvas>
    <script type="application/json" id={`${safeId}-data`} set:html={payload}></script>
  </div>
)}

<script>
  import { Chart, registerables } from "chart.js";
  Chart.register(...registerables);

  type Pt = { date: string; value: number };
  const slice = (series: Pt[], range: string) => {
    if (range === "all") return series;
    const n = parseInt(range, 10);
    return Number.isFinite(n) ? series.slice(-n) : series;
  };

  const init = (canvas: HTMLCanvasElement) => {
    const dataEl = document.getElementById(`${canvas.id}-data`);
    if (!dataEl?.textContent) return;
    const { series, label, unit, color } = JSON.parse(dataEl.textContent);

    const render = (visible: Pt[]) => ({
      labels: visible.map((p) => p.date),
      datasets: [{
        label,
        data: visible.map((p) => p.value),
        borderColor: color,
        backgroundColor: color + "22",
        tension: 0.25,
        fill: true,
        pointRadius: 3,
      }],
    });

    const chart = new Chart(canvas, {
      type: "line",
      data: render(series),
      options: {
        responsive: true,
        maintainAspectRatio: false,
        interaction: { mode: "index", intersect: false },
        plugins: {
          legend: { display: false },
          tooltip: {
            callbacks: { label: (ctx) => `${ctx.parsed.y.toLocaleString("fr-FR")} ${unit}`.trim() },
          },
        },
        scales: {
          y: { ticks: { callback: (v) => Number(v).toLocaleString("fr-FR") }, grid: { color: "#0f111510" } },
          x: { grid: { display: false } },
        },
      },
    });

    document.querySelectorAll<HTMLButtonElement>(`.range-btn[data-target="${canvas.id}"]`).forEach((btn) => {
      btn.addEventListener("click", () => {
        const range = btn.dataset.range ?? "all";
        chart.data = render(slice(series, range));
        chart.update();
        document.querySelectorAll<HTMLButtonElement>(`.range-btn[data-target="${canvas.id}"]`).forEach((b) => {
          b.dataset.active = String(b === btn);
        });
      });
    });
  };

  const observer = new IntersectionObserver((entries) => {
    for (const e of entries) {
      if (e.isIntersecting) {
        init(e.target as HTMLCanvasElement);
        observer.unobserve(e.target);
      }
    }
  });
  document.querySelectorAll<HTMLCanvasElement>('canvas[id^="chart-"]').forEach((c) => observer.observe(c));
</script>
