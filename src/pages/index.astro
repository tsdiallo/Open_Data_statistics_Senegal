---
import Base from "@/components/layout/Base.astro";
import { datasetMeta, demographyData, economyData, findIndicator, latestPoint } from "@/lib/datasets";
import { computeStats } from "@/lib/analytics";
import { formatDate, formatNumber, formatPercent } from "@/lib/format";

const pop = findIndicator(demographyData.indicators, "population-total");
const life = findIndicator(demographyData.indicators, "esperance-vie");
const gdp = findIndicator(economyData.indicators, "pib-courant");
const growth = findIndicator(economyData.indicators, "croissance-pib");
const inflation = findIndicator(economyData.indicators, "inflation");

const popLatest = pop ? latestPoint(pop.series) : null;
const lifeLatest = life ? latestPoint(life.series) : null;
const gdpLatest = gdp ? latestPoint(gdp.series) : null;
const growthStats = growth ? computeStats(growth.series) : null;
const inflationLatest = inflation ? latestPoint(inflation.series) : null;

const snapshots = [
  pop && popLatest && {
    eyebrow: "Habitants",
    value: formatNumber(popLatest.value ?? 0, { compact: true }),
    unit: "",
    year: popLatest.date,
    href: "/demographie",
    tint: "text-baobab-700",
  },
  gdp && gdpLatest && {
    eyebrow: "PIB nominal",
    value: formatNumber(gdpLatest.value ?? 0, { compact: true }),
    unit: "Mds USD",
    year: gdpLatest.date,
    href: "/economie",
    tint: "text-baobab-700",
  },
  inflation && inflationLatest && {
    eyebrow: "Inflation",
    value: formatPercent(inflationLatest.value ?? 0),
    unit: "",
    year: inflationLatest.date,
    href: "/economie",
    tint: "text-flag-red",
  },
  life && lifeLatest && {
    eyebrow: "Espérance de vie",
    value: (lifeLatest.value ?? 0).toFixed(1),
    unit: "ans",
    year: lifeLatest.date,
    href: "/demographie",
    tint: "text-ink-900",
  },
].filter(Boolean) as Array<{ eyebrow: string; value: string; unit: string; year: string; href: string; tint: string }>;

const sections = [
  {
    href: "/demographie",
    title: "Démographie",
    desc: "Population, urbanisation, espérance de vie. 25 ans d'évolution, explorables année par année.",
    badge: "ANSD · Banque mondiale",
  },
  {
    href: "/economie",
    title: "Économie",
    desc: "PIB, croissance, inflation, dette publique. Historique FMI + projections jusqu'en 2031.",
    badge: "FMI · Banque mondiale",
  },
  {
    href: "/climat",
    title: "Climat",
    desc: "Températures min/moy/max, pluies, prévisions 7 jours sur six grandes villes.",
    badge: "Open-Meteo · ANACIM",
  },
];
---
<Base title="Sénégal en chiffres" description="Visualisations claires et expliquées des données publiques du Sénégal.">
  <section class="grid gap-10 lg:grid-cols-[1.25fr_1fr] lg:items-end pt-4 sm:pt-10">
    <div class="space-y-6">
      <p class="eyebrow">Données ouvertes · expliquées simplement</p>
      <h1 class="display text-5xl sm:text-6xl lg:text-7xl text-ink-900 leading-[0.95]">
        Comprendre le Sénégal, <em class="text-baobab-700">en quelques chiffres</em>.
      </h1>
      <p class="text-lg text-ink-700 max-w-prose leading-relaxed">
        Une plateforme libre qui rassemble les données démographiques, économiques et climatiques
        publiées par l'ANSD, l'ANACIM, le FMI et la Banque mondiale — avec une explication
        accessible, des filtres, un tableau de données et un export CSV pour chaque indicateur.
      </p>
      <div class="flex flex-wrap gap-3 pt-1">
        <a href="/economie" class="btn-primary">Explorer les indicateurs →</a>
        <a href="/methodologie" class="btn-ghost">Sources & méthodologie</a>
      </div>
      <p class="text-xs text-ink-500">Dernière génération du site : {formatDate(datasetMeta.generatedAt)}</p>
    </div>
    <aside class="relative">
      <div class="card bg-ink-900 text-paper border-ink-900 overflow-hidden">
        <p class="eyebrow text-sun-500">Notre engagement</p>
        <ul class="mt-4 space-y-3 text-sm leading-relaxed">
          <li class="flex gap-3"><span class="text-sun-500" aria-hidden="true">—</span>Aucune donnée inventée.</li>
          <li class="flex gap-3"><span class="text-sun-500" aria-hidden="true">—</span>Source, date et nature affichées partout.</li>
          <li class="flex gap-3"><span class="text-sun-500" aria-hidden="true">—</span>Historique et projections visuellement distingués.</li>
          <li class="flex gap-3"><span class="text-sun-500" aria-hidden="true">—</span>Chaque série exportable en CSV.</li>
        </ul>
      </div>
    </aside>
  </section>

  {snapshots.length > 0 && (
    <section class="mt-16 sm:mt-24">
      <div class="flex items-baseline justify-between gap-4 mb-6">
        <h2 class="h-section">Le Sénégal, aujourd'hui</h2>
        <p class="text-sm text-ink-500">Dernières valeurs disponibles.</p>
      </div>
      <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {snapshots.map((s) => (
          <a href={s.href} class="card group hover:border-baobab-700/30 transition flex flex-col gap-2">
            <span class="eyebrow">{s.eyebrow}</span>
            <p class={`display text-4xl sm:text-5xl leading-none num ${s.tint}`}>
              {s.value}
              {s.unit && <span class="text-ink-500 text-base font-sans ml-1.5">{s.unit}</span>}
            </p>
            <p class="text-xs text-ink-500 mt-auto">Année {s.year}</p>
          </a>
        ))}
      </div>
    </section>
  )}

  <section class="mt-16 sm:mt-24">
    <div class="flex items-baseline justify-between gap-4 mb-8">
      <h2 class="h-section">Explorer par catégorie</h2>
      <p class="text-sm text-ink-500">Trois portes d'entrée pour un pays en mouvement.</p>
    </div>
    <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {sections.map((s) => (
        <a href={s.href} class="card group hover:border-baobab-700/30 transition flex flex-col gap-3">
          <span class="eyebrow">{s.badge}</span>
          <h3 class="display text-2xl text-ink-900 group-hover:text-baobab-700 transition">{s.title}</h3>
          <p class="text-sm text-ink-700 leading-relaxed">{s.desc}</p>
          <span class="text-sm font-medium text-baobab-700 mt-auto inline-flex items-center gap-1 group-hover:gap-2 transition-all">
            Voir les données <span aria-hidden="true">→</span>
          </span>
        </a>
      ))}
    </div>
  </section>
</Base>
