---
import Base from "@/components/layout/Base.astro";
import { datasetMeta } from "@/lib/datasets";
import { formatDate } from "@/lib/format";

const sections = [
  {
    href: "/demographie",
    title: "Démographie",
    desc: "Population, urbanisation, espérance de vie. Comprendre qui vit au Sénégal et comment cela évolue.",
    badge: "ANSD · Banque mondiale",
  },
  {
    href: "/economie",
    title: "Économie & macro",
    desc: "PIB, croissance, inflation, dette publique. Lire l'économie sénégalaise sans jargon.",
    badge: "FMI",
  },
  {
    href: "/climat",
    title: "Climat & météo",
    desc: "Températures, précipitations, prévisions par grande ville. Données quasi temps réel.",
    badge: "Open-Meteo · ANACIM",
  },
];
---
<Base title="Sénégal en chiffres" description="Visualisations claires et expliquées des données publiques du Sénégal.">
  <section class="grid gap-8 lg:grid-cols-[1.2fr_1fr] items-center">
    <div class="space-y-4">
      <p class="inline-flex items-center gap-2 rounded-full bg-sand-100 text-baobab-800 px-3 py-1 text-xs font-medium">
        Données ouvertes · expliquées simplement
      </p>
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-tight text-baobab-800">
        Comprendre le Sénégal en quelques chiffres clés.
      </h1>
      <p class="text-lg text-ink-700 max-w-prose">
        Une plateforme libre qui rassemble les données démographiques, économiques et climatiques
        publiées par l'ANSD, l'ANACIM, le FMI et la Banque mondiale, avec une explication
        accessible pour chaque indicateur.
      </p>
      <div class="flex flex-wrap gap-3 pt-2">
        <a href="/economie" class="inline-flex items-center rounded-lg bg-baobab-700 hover:bg-baobab-800 text-white px-4 py-2 text-sm font-medium">
          Explorer les indicateurs
        </a>
        <a href="/methodologie" class="inline-flex items-center rounded-lg ring-1 ring-ink-900/10 bg-white hover:bg-sand-100 px-4 py-2 text-sm font-medium text-ink-700">
          Sources & méthodologie
        </a>
      </div>
      <p class="text-xs text-ink-500">
        Dernière génération du site : {formatDate(datasetMeta.generatedAt)}
      </p>
    </div>
    <div class="card bg-baobab-700 text-white">
      <p class="text-sm uppercase tracking-wider text-sand-100/80">Notre engagement</p>
      <ul class="mt-3 space-y-2 text-sm">
        <li>· Aucune donnée inventée.</li>
        <li>· Source et date affichées sur chaque graphique.</li>
        <li>· Distinction claire entre historique, estimation, projection et prévision.</li>
        <li>· Code ouvert, déployé statiquement.</li>
      </ul>
    </div>
  </section>

  <section class="mt-12 sm:mt-16">
    <h2 class="h-section">Explorer par catégorie</h2>
    <div class="mt-6 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
      {sections.map((s) => (
        <a href={s.href} class="card group hover:ring-baobab-700/30 transition flex flex-col gap-3">
          <span class="text-xs font-medium text-ink-500">{s.badge}</span>
          <h3 class="text-xl font-semibold text-baobab-800 group-hover:text-baobab-700">{s.title}</h3>
          <p class="text-sm text-ink-700">{s.desc}</p>
          <span class="text-sm font-medium text-baobab-700 mt-auto">Voir les données →</span>
        </a>
      ))}
    </div>
  </section>
</Base>
